{
  "name": "palavra-viva-functions",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "serve": "firebase emulators:start --only functions,firestore,auth,storage,pubsub --config ../firebase/firebase.json",
    "shell": "firebase functions:shell --config ../firebase/firebase.json",
    "deploy": "firebase deploy --only functions,firestore,storage --config ../firebase/firebase.json"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^5.1.1"
  }
}
